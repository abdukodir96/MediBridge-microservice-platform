generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PaymentStatus {
  PENDING
  HELD
  RELEASED
  REFUNDED
}

enum ContractStatus {
  DRAFT
  SIGNED_PATIENT
  SIGNED_BOTH
  VOID
}

enum TxType {
  CHARGE
  RELEASE
  REFUND
}

model Payment {
  id             String        @id @default(uuid())
  status         PaymentStatus @default(PENDING)
  bookingId      String        // Core's Booking ObjectId (cross-service ref)
  patientId      String        // Core's Member ObjectId
  clinicId       String        // Core's Clinic ObjectId
  amount         Decimal       @db.Decimal(12, 2) // money — DECIMAL, never float
  currency       String        @default("USD")
  stripeId       String?       // Stripe reference (later)
  idempotencyKey String        @unique // prevents double-charging
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  transactions Transaction[]
  contract     Contract?

  @@index([bookingId])
  @@index([patientId])
}

model Contract {
  id        String         @id @default(uuid())
  status    ContractStatus @default(DRAFT)
  bookingId String
  terms     String         @default("")
  pdfPath   String?
  paymentId String         @unique
  payment   Payment        @relation(fields: [paymentId], references: [id])
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model Transaction {
  id        String   @id @default(uuid())
  type      TxType
  amount    Decimal  @db.Decimal(12, 2)
  paymentId String
  payment   Payment  @relation(fields: [paymentId], references: [id])
  createdAt DateTime @default(now())
  // Transaction is an immutable audit log — never updated or deleted
}
